{
  "name": "cf-crawl",
  "packageManager": "pnpm@11.1.1",
  "version": "1.0.0",
  "description": "Crawl and scrape websites using the Cloudflare Browser Rendering API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cf-crawl": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx index.ts",
    "crawl": "tsx index.ts crawl",
    "crawl:render": "tsx index.ts crawl --render",
    "scrape": "tsx index.ts scrape",
    "markdown": "tsx index.ts markdown",
    "content": "tsx index.ts content",
    "links": "tsx index.ts links",
    "json": "tsx index.ts json",
    "pdf": "tsx index.ts pdf",
    "screenshot": "tsx index.ts screenshot",
    "snapshot": "tsx index.ts snapshot",
    "tomarkdown": "tsx index.ts tomarkdown",
    "status": "tsx index.ts status",
    "download": "tsx index.ts download",
    "jobs": "tsx index.ts jobs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
