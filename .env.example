# Cloudflare Browser Rendering API credentials
# Copy this file to .env and fill in your values
#
# Find your Account ID: https://dash.cloudflare.com → any domain → Overview → right sidebar
# Create an API Token: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → Custom Token → Permissions: Browser Rendering: Edit

CF_ACCOUNT_ID=your_account_id_here
CF_API_TOKEN=your_api_token_here
